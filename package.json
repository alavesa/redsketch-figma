{
  "name": "redsketch-figma",
  "version": "1.0.0",
  "description": "Figma plugin — threat-model your designs before writing code",
  "scripts": {
    "build": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --sourcemap && cp ui/ui.html dist/ui.html",
    "watch": "esbuild src/code.ts --bundle --outfile=dist/code.js --target=es2017 --sourcemap --watch & cp ui/ui.html dist/ui.html"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
